<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="12.0" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/17"
      fx:controller="com.diego.projetop3.CadastroController"
      prefWidth="400.0" prefHeight="550.0"
      style="-fx-background-color: #f4f4f4;">

    <padding>
        <Insets bottom="25.0" left="30.0" right="30.0" top="25.0"/>
    </padding>

    <Label text="Cadastro de Usuário">
        <font>
            <Font name="System Bold" size="20.0" />
        </font>
        <VBox.margin>
            <Insets bottom="10.0" />
        </VBox.margin>
    </Label>

    <VBox spacing="3.0" alignment="CENTER_LEFT">
        <Label text="Nome Completo:" />
        <TextField fx:id="nomeUsuario" promptText="Digite seu nome" prefHeight="30.0"/>
    </VBox>

    <VBox spacing="3.0" alignment="CENTER_LEFT">
        <Label text="Idade:" />
        <TextField fx:id="idadeUsuario" promptText="Ex: 25" prefHeight="30.0"/>
    </VBox>

    <VBox spacing="3.0" alignment="CENTER_LEFT">
        <Label text="CPF:" />
        <TextField fx:id="cpfUsuario" promptText="000.000.000-00" prefHeight="30.0"/>
    </VBox>

    <VBox spacing="3.0" alignment="CENTER_LEFT">
        <Label text="Número de Telefone:" />
        <TextField fx:id="telefoneUsuario" promptText="(00) 00000-0000" prefHeight="30.0"/>
    </VBox>

    <VBox spacing="3.0" alignment="CENTER_LEFT">
        <Label text="Peso (kg):" />
        <TextField fx:id="pesoUsuario" promptText="Ex: 75.5" prefHeight="30.0"/>
    </VBox>

    <Label fx:id="mensagemLabel" text="" wrapText="true">
        <font>
            <Font size="12.0" />
        </font>
    </Label>

    <Button fx:id="botaoSalvarCadastro" text="Salvar" onAction="#onSalvarButtonClick"
            prefWidth="Infinity" prefHeight="35.0"
            style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-cursor: hand; -fx-font-weight: bold;">
        <font>
            <Font size="14.0" />
        </font>
    </Button>

    <Button fx:id="botaoVoltarLogin" text="Voltar para o Login" onAction="#onVoltarButtonClick"
            prefWidth="Infinity" prefHeight="30.0"
            style="-fx-background-color: transparent; -fx-text-fill: #0078D7; -fx-cursor: hand; -fx-underline: true;">
        <font>
            <Font size="12.0" />
        </font>
    </Button>
</VBox>